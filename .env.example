# AWS Configuration
AWS_PROFILE=default
AWS_REGION=us-east-1

# Bedrock Model
# Use inference profile IDs (not raw model IDs) for on-demand throughput
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# Environment
ENVIRONMENT=dev
LOG_LEVEL=INFO

# Knowledge Base (populated after terraform apply)
KNOWLEDGE_BASE_ID=
S3_KB_BUCKET=

# Secrets Manager (set ARN to load secrets from AWS instead of .env)
SECRETS_ARN=

# Chat UI
CHAT_AGENT_TYPE=react
CHAT_PORT=8000
CHAT_AUTH_SECRET=
CHAT_AUTH_USERNAME=admin
CHAT_AUTH_PASSWORD=
CHAT_PERSISTENCE=memory
CHAT_SQLITE_PATH=.chat_history.db
CHAT_RATE_LIMIT=0
CHAT_THEME=

# AgentCore (all opt-in, disabled by default)
AGENTCORE_MEMORY_ENABLED=false
AGENTCORE_GATEWAY_ENABLED=false
AGENTCORE_OBSERVABILITY_ENABLED=false
AGENTCORE_RUNTIME_PORT=8080
AGENTCORE_AGENT_NAME=agentic-ai
